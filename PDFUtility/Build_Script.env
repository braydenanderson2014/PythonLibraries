# PyInstaller Build Tool Enhanced - Environment Configuration
# This file contains configuration settings for the build tool
# Edit these values to match your GitHub repository and preferences

# GitHub Repository Configuration for Update System
GITHUB_REPO_OWNER=braydenanderson2014
GITHUB_REPO_NAME=Build_Script
# Get your GitHub token from: https://github.com/settings/tokens
# Token only needs 'public_repo' scope for accessing releases
