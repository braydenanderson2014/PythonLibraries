# PyInstaller Build Tool Enhanced - Environment Configuration Example
# Copy this file to 'Build_Script.env' and edit the values below
# This file contains configuration settings for the build tool

# GitHub Repository Configuration for Update System
# Edit these to match your actual GitHub repository
GITHUB_REPO_OWNER=your-github-username
GITHUB_REPO_NAME=pyinstaller-build-tool
CURRENT_VERSION=2.0.0-enhanced

# Build Tool Configuration
BUILD_TOOL_NAME=PyInstaller Build Tool Enhanced
BUILD_TOOL_AUTHOR=Enhanced Build System  
BUILD_TOOL_DESCRIPTION=Advanced PyInstaller GUI and Console Tool

# Update System Settings
UPDATE_CHECK_TIMEOUT=10
UPDATE_AUTO_CONFIRM=false
UPDATE_CREATE_BACKUP=true

# Virtual Environment Settings
DEFAULT_VENV_NAME=build_env
VENV_AUTO_INSTALL=true

# Project Creation Defaults
DEFAULT_PROJECT_VERSION=1.0.0
DEFAULT_PROJECT_AUTHOR=Your Name Here

# Advanced Settings
DEBUG_MODE=false
VERBOSE_OUTPUT=false
SAFE_MODE=true

# Instructions:
# 1. Copy this file to 'Build_Script.env' (remove .example extension)
# 2. Edit the GITHUB_REPO_OWNER and GITHUB_REPO_NAME values
# 3. Update CURRENT_VERSION when you release new versions
# 4. Customize other settings as needed
# 5. Add 'Build_Script.env' to your .gitignore (but not this example file)
