{
  "dry_run": true,
  "organize_movies": true,
  "organize_tv": true,
  "recursive_tv_scan": true,
  "cleanup_empty_movie_folders": true,
  "online_lookup": {
    "enabled": true,
    "timeout_seconds": 8,
    "movie_provider": "itunes",
    "tv_provider": "tvmaze",
    "include_episode_title": true
  },
  "preserve": {
    "enabled": true,
    "fields": [
      "resolution",
      "source",
      "codec"
    ],
    "separator": " ",
    "style": "brackets",
    "extra_regex": []
  },
  "movie_name": {
    "template": "{title} ({year}){trait_suffix}",
    "normalize_separators": true,
    "strip_bracketed": true,
    "cutoff_tokens": [
      "\\b2160p\\b",
      "\\b1080p\\b",
      "\\b720p\\b",
      "\\bWEB[-_. ]?DL\\b",
      "\\bWEB[-_. ]?Rip\\b",
      "\\bBluRay\\b",
      "\\bBRRip\\b",
      "\\bx264\\b",
      "\\bx265\\b",
      "\\bHEVC\\b",
      "\\bAAC\\b",
      "\\bDDP?5\\.1\\b",
      "\\bYTS\\b",
      "\\bRARBG\\b"
    ],
    "cleanup_regex": [
      {
        "pattern": "[-_]+",
        "replace": " "
      }
    ]
  },
  "tv_name": {
    "template": "{clean_name} - {season_episode}{episode_title_suffix}{trait_suffix}",
    "normalize_separators": true,
    "strip_bracketed": true,
    "patterns": [
      {
        "pattern": "(?i)S(?P<season>\\d{1,2})E(?P<episode>\\d{1,3})",
        "season_group": "season",
        "episode_group": "episode"
      },
      {
        "pattern": "(?i)(?P<season>\\d{1,2})x(?P<episode>\\d{1,3})",
        "season_group": "season",
        "episode_group": "episode"
      },
      {
        "pattern": "(?i)Season[ ._-]?(?P<season>\\d{1,2})[ ._-]*Episode[ ._-]?(?P<episode>\\d{1,3})",
        "season_group": "season",
        "episode_group": "episode"
      }
    ],
    "cutoff_tokens": [
      "\\b2160p\\b",
      "\\b1080p\\b",
      "\\b720p\\b",
      "\\bWEB[-_. ]?DL\\b",
      "\\bWEB[-_. ]?Rip\\b",
      "\\bBluRay\\b",
      "\\bBRRip\\b",
      "\\bx264\\b",
      "\\bx265\\b",
      "\\bHEVC\\b",
      "\\bAAC\\b",
      "\\bDDP?5\\.1\\b",
      "\\bYTS\\b",
      "\\bRARBG\\b"
    ],
    "cleanup_regex": [
      {
        "pattern": "[-_]+",
        "replace": " "
      }
    ]
  }
}
