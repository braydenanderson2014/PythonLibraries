{
  "bhyve": {
    "email": "Email@email.com",
    "password_env": "BHYVE_PASSWORD",
    "poll_interval_seconds": 10,
    "request_timeout_seconds": 30
  },
  "weather": {
    "provider": "open_meteo",
    "latitude": 40.7608,
    "longitude": -111.891,
    "temperature_unit": "fahrenheit"
  },
  "controller": {
    "schedule_guard_minutes": 30,
    "default_cooldown_minutes": 120,
    "default_max_runs_per_day": 3,
    "state_file": ".bhyve_state.json"
  },
  "ingest": {
    "serial": {
      "enabled": false,
      "port": "COM3",
      "baudrate": 115200,
      "read_timeout_seconds": 1,
      "reconnect_seconds": 5
    },
    "bluetooth": {
      "enabled": false,
      "address": "",
      "characteristic_uuid": "",
      "reconnect_seconds": 5
    }
  },
  "devices": [
    {
      "device_id": "replace-with-device-id-1",
      "block_unlisted_stations": false
    },
    {
      "device_id": "replace-with-broken-pipes-device-id",
      "block_unlisted_stations": true
    }
  ],
  "rules": [
    {
      "name": "Front Lawn Heat Boost",
      "device_id": "replace-with-device-id",
      "station": 1,
      "start_above": 88,
      "stop_below": 78,
      "manual_run_minutes": 10,
      "cooldown_minutes": 180,
      "max_runs_per_day": 2,
      "allowed_hours_local": [
        10,
        19
      ],
      "enabled": true
    }
  ]
}
